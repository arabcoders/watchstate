{
    "name": "nuxt-app",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "typecheck": "nuxt typecheck",
        "format": "oxfmt --write app",
        "format:check": "oxfmt --check  app",
        "lint": "eslint .",
        "lint:ci": "eslint . --quiet",
        "lint:fix": "eslint . --fix",
        "lint:tsc": "vue-tsc --noEmit",
        "test": "bun test",
        "test:watch": "bun test --watch",
        "test:ci": "bun test --dots",
        "prepare:test": "nuxt prepare --envName=development"
    },
    "dependencies": {
        "@iconify-json/lucide": "^1.2.103",
        "@microsoft/fetch-event-source": "^2.0.1",
        "@nuxt/eslint": "^1.15.2",
        "@nuxt/eslint-config": "^1.15.2",
        "@nuxt/ui": "^4.7.0",
        "@pinia/nuxt": "^0.11.3",
        "@vueuse/core": "^14.2.1",
        "@vueuse/nuxt": "^14.2.1",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/xterm": "^6.0.0",
        "cronstrue": "^3.14.0",
        "hls.js": "^1.6.16",
        "marked": "^18.0.2",
        "marked-alert": "^2.1.2",
        "marked-base-url": "^1.1.9",
        "marked-gfm-heading-id": "^4.1.4",
        "moment": "^2.30.1",
        "nuxt": "^4.4.2",
        "pinia": "^3.0.4",
        "plyr": "^3.8.4",
        "tailwindcss": "^4.2.4",
        "vue": "^3.5.33",
        "vue-router": "^5.0.6",
        "vuedraggable": "^4.1.0"
    },
    "overrides": {
        "vuedraggable": "^4.1.0"
    },
    "trustedDependencies": [
        "esbuild",
        "@parcel/watcher"
    ],
    "devDependencies": {
        "@types/bun": "^1.3.13",
        "@types/node": "25.6.0",
        "@typescript-eslint/parser": "^8.59.0",
        "eslint": "^10.2.1",
        "oxfmt": "^0.46.0",
        "typescript": "^6.0.3",
        "vue-eslint-parser": "^10.4.0",
        "vue-tsc": "^3.2.7"
    },
    "eslintIgnore": [
        ".gitignore"
    ]
}
